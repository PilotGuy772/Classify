
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- macOS-specific theme resources and class-based styles.
       This file implements the color and styling rules from Styles/colors.txt.
       All selectors require the `platform-macos` class on a visual root so these
       styles apply only on macOS.
  -->

  <!-- Resource brushes -->
  <Styles.Resources>
    <!-- Default (Light) brushes -->
    <SolidColorBrush x:Key="Accent" Color="#0088FF" />
    <SolidColorBrush x:Key="MainBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SecondaryBackground" Color="#F7F7F7" />
    <SolidColorBrush x:Key="SelectedBackground" Color="#E6E6E6" />
    <SolidColorBrush x:Key="StandardButtonBackground" Color="#F2F2F2" />
    <SolidColorBrush x:Key="PrimaryButtonBackground" Color="#0088FF" />
    <SolidColorBrush x:Key="Outline" Color="#D2D2D2" />
    <SolidColorBrush x:Key="Text" Color="#000000" />
    <SolidColorBrush x:Key="SecondaryText" Color="#8E8E93" />
    <SolidColorBrush x:Key="TertiaryText" Color="#FFFFFF" />

    <!-- Dark theme brush variants (referenced by theme-specific control overrides) -->
    <SolidColorBrush x:Key="Accent.Dark" Color="#0088FF" />
    <SolidColorBrush x:Key="MainBackground.Dark" Color="#2C2C2C" />
    <SolidColorBrush x:Key="SecondaryBackground.Dark" Color="#37373A" />
    <SolidColorBrush x:Key="SelectedBackground.Dark" Color="#4E4E52" />
    <SolidColorBrush x:Key="StandardButtonBackground.Dark" Color="#00000000" />
    <SolidColorBrush x:Key="PrimaryButtonBackground.Dark" Color="#00000000" />
    <SolidColorBrush x:Key="Outline.Dark" Color="#8E8E93" />
    <SolidColorBrush x:Key="Text.Dark" Color="#DBDBDB" />
    <SolidColorBrush x:Key="SecondaryText.Dark" Color="#8E8E93" />
    <SolidColorBrush x:Key="TertiaryText.Dark" Color="#0088FF" />
  </Styles.Resources>

  <!-- Sidebar: main left navigation background -->
  <Style Selector="Window.platform-macos StackPanel.sidebar">
    <Setter Property="Background" Value="{StaticResource SecondaryBackground}" />
  </Style>

  <!-- Titlebar: keep minimal; TODO about traffic-light safe area -->
  <Style Selector="Border.titlebar.platform-macos">
    <Setter Property="Background" Value="{StaticResource SecondaryBackground}" />
    <!-- Do not hardcode left padding for traffic lights. Use ExtendClientArea APIs in future. -->
  </Style>

  <!-- Search box inside titlebar and free-entry TextBoxes: use Secondary Background and SecondaryText for watermark -->
  <Style Selector="Border.titlebar.platform-macos TextBox, TextBox.platform-macos">
    <Setter Property="Background" Value="{StaticResource SecondaryBackground}" />
    <Setter Property="Foreground" Value="{StaticResource Text}" />
    <Setter Property="CaretBrush" Value="{StaticResource Text}" />
    <Setter Property="BorderBrush" Value="{StaticResource Outline}" />
    <Setter Property="CornerRadius" Value="15" />
    <!-- Watermark/placeholder color is provided by control template; adjust template if needed. -->
  </Style>

  <!-- General Buttons on macOS -> include platform-macos usage where appropriate in other selectors -->
  <Style Selector="Window.platform-macos Button">
    <Setter Property="CornerRadius" Value="15" />
    <Setter Property="Foreground" Value="{StaticResource Text}" />
    <Setter Property="Background" Value="{StaticResource StandardButtonBackground}" />
    <Setter Property="BorderBrush" Value="{StaticResource Outline}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <!-- Standard Buttons pressed state: take SelectedBackground -->
  <Style Selector="Button.platform-macos:pressed">
    <Setter Property="Background" Value="{StaticResource SelectedBackground}" />
  </Style>

  <!-- Toolbar Buttons: transparent by default, no outline -->
  <Style Selector="Button.toolbar-button.platform-macos">
    <Setter Property="CornerRadius" Value="15" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource Text}" />
  </Style>

  <!-- Toolbar button hover feedback -->
  <Style Selector="Button.toolbar-button.platform-macos:pointerover">
    <Setter Property="Background" Value="{StaticResource SelectedBackground}" />
  </Style>

  <!-- Navigation selection for plain Buttons: app should add Classes="selected" to the active nav Button -->
  <Style Selector="Button.toolbar-button.selected.platform-macos">
    <Setter Property="Background" Value="{StaticResource SelectedBackground}" />
  </Style>

  <!-- Primary Buttons: bold text uses TertiaryText -->
  <Style Selector="Button.primary.platform-macos">
    <Setter Property="CornerRadius" Value="15" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource TertiaryText}" />
  </Style>

  <!-- Primary specifics per theme -->
  <Style Selector="Application.platform-macos[RequestedThemeVariant=Light] Button.primary.platform-macos">
    <Setter Property="Background" Value="{StaticResource Accent}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="Application.platform-macos[RequestedThemeVariant=Dark] Button.primary.platform-macos">
    <Setter Property="Background" Value="{StaticResource PrimaryButtonBackground}" />
    <Setter Property="BorderBrush" Value="{StaticResource Outline}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <!-- Primary pressed state -->
  <Style Selector="Button.primary.platform-macos:pressed">
    <Setter Property="Background" Value="{StaticResource SelectedBackground}" />
  </Style>

</Styles>

