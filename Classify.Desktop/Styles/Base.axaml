
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="MainBackgroundBrush">#FFFFFF</SolidColorBrush>
          <SolidColorBrush x:Key="SecondaryBackgroundBrush">#F7F7F7</SolidColorBrush>
          <SolidColorBrush x:Key="SelectedBackgroundBrush">#E6E6E6</SolidColorBrush>
          <SolidColorBrush x:Key="OutlineBrush">#D2D2D2</SolidColorBrush>
          <SolidColorBrush x:Key="TextBrush">#000000</SolidColorBrush>
          <SolidColorBrush x:Key="SecondaryTextBrush">#8E8E93</SolidColorBrush>
          <SolidColorBrush x:Key="AccentBrush">#0088FF</SolidColorBrush>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="MainBackgroundBrush">#2C2C2C</SolidColorBrush>
          <SolidColorBrush x:Key="SecondaryBackgroundBrush">#37373A</SolidColorBrush>
          <SolidColorBrush x:Key="SelectedBackgroundBrush">#4E4E52</SolidColorBrush>
          <SolidColorBrush x:Key="OutlineBrush">#8E8E93</SolidColorBrush>
          <SolidColorBrush x:Key="TextBrush">#DBDBDB</SolidColorBrush>
          <SolidColorBrush x:Key="SecondaryTextBrush">#8E8E93</SolidColorBrush>
          <SolidColorBrush x:Key="AccentBrush">#0088FF</SolidColorBrush>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource MainBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>

  <Style Selector="Border.titlebar">
    <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource OutlineBrush}" />
    <Setter Property="CornerRadius" Value="12" />
  </Style>

  <Style Selector="Border.sidebar">
    <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource OutlineBrush}" />
    <Setter Property="BorderThickness" Value="0,2,2,0" />
    <Setter Property="CornerRadius" Value="0,20,0,20" />
    <Setter Property="Padding" Value="12" />
    <!-- Hide overflow like HTML 'overflow: hidden' -->
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="Button.sidebar-main-title">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="15" />
    <!-- Main title container matches Figma: 230x61 with 12px inner padding -->
    <Setter Property="Width" Value="230" />
    <Setter Property="Height" Value="61" />
    <Setter Property="Padding" Value="12" />
    <!-- Ensure content is centered vertically inside the title button -->
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
  </Style>

  <Style Selector="TextBlock.sidebar-main-title-text">
    <!-- Title text per Figma: 24px bold -->
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="700" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="Width" Value="164" />
    <!-- Let the text block center vertically inside the title button -->
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.sidebar-category-title">
    <!-- Category titles (e.g. 'Library', 'Listen') per Figma -->
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="700" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <!-- Figma places a small left padding/margin inside a 205px container -->
    <Setter Property="Margin" Value="10,0,0,0" />
    <Setter Property="Width" Value="150" />
    <!-- Let the category title center vertically inside its container -->
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="Button.sidebar-nav-button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="15" />
    <!-- Nav item containers per Figma: 205x28 with horizontal padding 12 and vertical padding 4 -->
    <Setter Property="Width" Value="205" />
    <Setter Property="Height" Value="28" />
    <Setter Property="Padding" Value="12,4" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <!-- Center content vertically and ensure padding maps to 12px horizontal, 4px vertical -->
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
  </Style>

  <Style Selector="Button.sidebar-nav-button:pointerover">
    <Setter Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
  </Style>

  <Style Selector="Button.sidebar-nav-button:pressed">
    <Setter Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
  </Style>

  <Style Selector="Button.sidebar-nav-button.selected">
    <Setter Property="Background" Value="{DynamicResource SelectedBackgroundBrush}" />
  </Style>

  <Style Selector="TextBlock.sidebar-nav-icon">
    <!-- Icon container per Figma: 21x21, centered, accent outline simulated by color -->
    <Setter Property="Width" Value="21" />
    <Setter Property="Height" Value="21" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    <Setter Property="TextAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.sidebar-nav-label">
    <!-- Nav label typography per Figma: 16px regular, constrained width -->
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="400" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Width" Value="150" />
    <!-- Allow the label to size naturally to avoid clipping; vertical centering handled by the button -->
  </Style>

  <!-- Ensure spacing between groups in the sidebar matches the Figma outer gap -->
  <Style Selector="Border.sidebar StackPanel">
    <Setter Property="Spacing" Value="4" />
  </Style>

  <!-- Ensure StackPanels inside nav buttons center their children vertically and maintain spacing -->
  <Style Selector="Button.sidebar-nav-button StackPanel">
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Spacing" Value="12" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="Button.sidebar-main-title StackPanel">
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Spacing" Value="12" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>
</Styles>
