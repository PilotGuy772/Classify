<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Classify.Desktop.ViewModels"
             xmlns:ti="using:TablerIcons"
             xmlns:controls="clr-namespace:Classify.Desktop.Controls"
             mc:Ignorable="d" d:DesignWidth="304" d:DesignHeight="776"
             x:Class="Classify.Desktop.Views.ComposerInfoPanelView"
             x:DataType="viewModels:ComposerInfoPanelViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                   HorizontalScrollBarVisibility="Disabled">
        <Border Classes="info-panel">
            <StackPanel Spacing="10">
                <!-- Header: Close + Composer Name -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Button Grid.Column="0"
                            Classes="info-close"
                            Command="{Binding ClosePanelCommand}"
                            Margin="0,0,10,0">
                        <ti:TablerIcon Icon="IconX" Width="12" Height="12" />
                    </Button>
                    <TextBlock Grid.Column="1"
                               Classes="info-piece-title"
                               Text="{Binding Title}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                    <controls:OptionsButton Grid.Column="2" MenuOptions="{Binding MenuOptions}" />
                </Grid>

                <!-- Quick Info Placeholder -->
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0"
                            Classes="info-cover-placeholder"
                            VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0"
                                Spacing="4"
                                VerticalAlignment="Top">
                        <TextBlock Classes="info-meta-text"
                                   Text="Composer Profile"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="info-meta-text"
                                   Text="Historical Era / Details"
                                   TextWrapping="Wrap"
                                   Opacity="0.6" />
                    </StackPanel>
                </Grid>

                <!-- Large Actions Placeholder -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Classes="info-large-primary"
                            Width="58"
                            Height="35"
                            IsEnabled="False">
                        <ti:TablerIcon Icon="IconPlayerPlay" Width="16" Height="16" />
                    </Button>
                    <Button Classes="info-large-outline"
                            Width="100"
                            Height="35"
                            Content="Enqueue"
                            IsEnabled="False" />
                    <Button Classes="info-large-outline"
                            Width="100"
                            Height="35"
                            Content="Add to Playlist"
                            IsEnabled="False" />
                </StackPanel>

                <!-- Works List -->
                <StackPanel Spacing="4">
                    <TextBlock Classes="info-section-heading" Text="Works" />
                    <ItemsControl ItemsSource="{Binding WorkRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:WorkRowViewModel}">
                                 <Grid Margin="0,0,0,4"
                                       ColumnDefinitions="*,Auto"
                                       MinHeight="28">
                                     <Button Grid.Column="0"
                                             Classes="info-link"
                                             Command="{Binding ShowWorkCommand}">
                                         <TextBlock VerticalAlignment="Center"
                                                    FontSize="12"
                                                    Foreground="{DynamicResource TextBrush}"
                                                    Text="{Binding Name}"
                                                    TextWrapping="Wrap" />
                                     </Button>
                                     <controls:OptionsButton Grid.Column="1" MenuOptions="{Binding MenuOptions}" />
                                 </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
