<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Classify.Desktop.ViewModels"
             xmlns:ti="using:TablerIcons"
             mc:Ignorable="d" d:DesignWidth="304" d:DesignHeight="776"
             x:Class="Classify.Desktop.Views.MovementInfoPanelView"
             x:DataType="viewModels:MovementInfoPanelViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                   HorizontalScrollBarVisibility="Disabled">
        <Border Classes="info-panel">
            <StackPanel Spacing="10">
                <!-- Header: Close + Movement Name -->
                <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0"
                            Classes="info-close"
                            Command="{Binding ClosePanelCommand}"
                            Margin="0,0,10,0">
                        <ti:TablerIcon Icon="IconX" Width="12" Height="12" />
                    </Button>
                    <TextBlock Grid.Column="1"
                               Classes="info-piece-title"
                               Text="{Binding Title}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- Quick Info Placeholder -->
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0"
                            Classes="info-cover-placeholder"
                            VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0"
                                Spacing="4"
                                VerticalAlignment="Top">
                        <TextBlock Classes="info-meta-text"
                                   Text="Movement Details"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="info-meta-text"
                                   Text="Tempo / Key / Details"
                                   TextWrapping="Wrap"
                                   Opacity="0.6" />
                    </StackPanel>
                </Grid>

                <!-- Large Actions Placeholder -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Classes="info-large-primary"
                            Width="58"
                            Height="35"
                            IsEnabled="False">
                        <ti:TablerIcon Icon="IconPlayerPlay" Width="16" Height="16" />
                    </Button>
                    <Button Classes="info-large-outline"
                            Width="100"
                            Height="35"
                            Content="Enqueue"
                            IsEnabled="False" />
                    <Button Classes="info-large-outline"
                            Width="100"
                            Height="35"
                            Content="Add to Playlist"
                            IsEnabled="False" />
                </StackPanel>

                <!-- Parent Composer Section -->
                <StackPanel Spacing="4">
                    <TextBlock Classes="info-section-heading" Text="Composer" />
                    <Button Classes="info-link"
                            Command="{Binding ShowComposerCommand}">
                        <TextBlock Classes="info-meta-text"
                                   Text="{Binding ComposerName}"
                                   TextWrapping="Wrap" />
                    </Button>
                </StackPanel>

                <!-- Parent Work Section -->
                <StackPanel Spacing="4">
                    <TextBlock Classes="info-section-heading" Text="Work" />
                    <Grid ColumnDefinitions="*,Auto,Auto" MinHeight="28">
                        <Button Grid.Column="0"
                                Classes="info-link"
                                Command="{Binding ShowWorkCommand}">
                            <TextBlock Classes="info-meta-text"
                                       Text="{Binding WorkName}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Button Grid.Column="1"
                                Classes="info-small-accent"
                                Margin="4,0,4,0"
                                VerticalAlignment="Center"
                                Command="{Binding PlayWorkCommand}">
                            <ti:TablerIcon Icon="IconPlayerPlay" Width="12" Height="12" />
                        </Button>
                        <Button Grid.Column="2"
                                Classes="info-small-outline"
                                VerticalAlignment="Center"
                                Command="{Binding EnqueueWorkCommand}">
                            <ti:TablerIcon Icon="IconPlaylistAdd" Width="12" Height="12" />
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Recordings Section -->
                <StackPanel Spacing="4">
                    <TextBlock Classes="info-section-heading" Text="Recordings" />
                    <ScrollViewer MaxHeight="290"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RecordingRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:MovementRecordingRowViewModel}">
                                    <Grid Margin="0,0,0,4"
                                          ColumnDefinitions="*,Auto,Auto,Auto"
                                          MinHeight="31">
                                        <Button Grid.Column="0"
                                                Classes="info-link"
                                                Margin="0,0,8,0"
                                                Command="{Binding ShowMovementRecordingCommand}">
                                            <TextBlock FontSize="12"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       Text="{Binding DisplayText}"
                                                       TextWrapping="Wrap" />
                                        </Button>
                                        <Button Grid.Column="1"
                                                Classes="info-small-accent"
                                                Margin="4,0,4,0"
                                                VerticalAlignment="Center"
                                                Command="{Binding PlayRecordingRowCommand}">
                                            <ti:TablerIcon Icon="IconPlayerPlay" Width="12" Height="12" />
                                        </Button>
                                        <Button Grid.Column="2"
                                                Classes="info-small-outline"
                                                Margin="0,0,4,0"
                                                VerticalAlignment="Center"
                                                Command="{Binding EnqueueRecordingRowCommand}">
                                            <ti:TablerIcon Icon="IconPlaylistAdd" Width="12" Height="12" />
                                        </Button>
                                        <Button Grid.Column="3"
                                                Classes="info-small-outline"
                                                Classes.is-favorite="{Binding IsFavorite}"
                                                VerticalAlignment="Center"
                                                Command="{Binding ToggleFavoriteRecordingRowCommand}">
                                            <ti:TablerIcon Icon="IconStar" Width="12" Height="12" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
