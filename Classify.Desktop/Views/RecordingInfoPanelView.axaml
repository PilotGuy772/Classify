<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Classify.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="304" d:DesignHeight="776"
             x:Class="Classify.Desktop.Views.RecordingInfoPanelView"
             x:DataType="viewModels:RecordingInfoPanelViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                   HorizontalScrollBarVisibility="Disabled">
        <Border Classes="info-panel">
            <StackPanel Spacing="10">
                <!-- Header: Close + Recording Title -->
                <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0"
                            Classes="info-close"
                            Command="{Binding ClosePanelCommand}"
                            Content="×"
                            Margin="0,0,10,0" />
                    <TextBlock Grid.Column="1"
                               Classes="info-piece-title"
                               Text="{Binding Title}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- Quick Info Placeholder -->
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0"
                            Classes="info-cover-placeholder"
                            VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0"
                                Spacing="4"
                                VerticalAlignment="Top">
                        <TextBlock Classes="info-meta-text"
                                   Text="Recording Profile"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="info-meta-text"
                                   Text="Label / Format / Details"
                                   TextWrapping="Wrap"
                                   Opacity="0.6" />
                    </StackPanel>
                </Grid>

                <!-- Large Actions Placeholder -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Classes="info-large-primary"
                            Width="58"
                            Height="35"
                            Content="▶"
                            IsEnabled="False" />
                    <Button Classes="info-large-outline"
                            Width="100"
                            Height="35"
                            Content="Enqueue"
                            IsEnabled="False" />
                    <Button Classes="info-large-outline"
                            Width="100"
                            Height="35"
                            Content="Add to Playlist"
                            IsEnabled="False" />
                </StackPanel>

                <!-- Movements List grouped by Work -->
                <StackPanel Spacing="4">
                    <TextBlock Classes="info-section-heading" Text="Movements" />
                    <ScrollViewer MaxHeight="380"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding WorkGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:RecordingWorkGroupViewModel}">
                                    <StackPanel Margin="0,0,0,12">
                                        <!-- Emphasized Work Title -->
                                        <TextBlock FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Text="{Binding WorkTitle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6" />
                                        <!-- Movement recordings under this Work -->
                                        <ItemsControl ItemsSource="{Binding Movements}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:RecordingMovementRowViewModel}">
                                                    <Grid Margin="0,0,0,4"
                                                          ColumnDefinitions="Auto,*,Auto,Auto"
                                                          MinHeight="28">
                                                        <TextBlock Grid.Column="0"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextBrush}"
                                                                   Text="{Binding OrdinalLabel}"
                                                                   Width="28" />
                                                        <TextBlock Grid.Column="1"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextBrush}"
                                                                   Text="{Binding Name}"
                                                                   TextWrapping="Wrap" />
                                                        <Button Grid.Column="2"
                                                                Classes="info-small-accent"
                                                                Margin="4,0,4,0"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding PlayMovementRecordingRowCommand}"
                                                                Content="▶" />
                                                        <Button Grid.Column="3"
                                                                Classes="info-small-outline"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding EnqueueMovementRecordingRowCommand}"
                                                                Content="⏎" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
