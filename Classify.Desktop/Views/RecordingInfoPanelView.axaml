<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Classify.Desktop.ViewModels"
             xmlns:ti="using:TablerIcons"
             xmlns:controls="clr-namespace:Classify.Desktop.Controls"
             mc:Ignorable="d" d:DesignWidth="304" d:DesignHeight="776"
             x:Class="Classify.Desktop.Views.RecordingInfoPanelView"
             x:DataType="viewModels:RecordingInfoPanelViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                   HorizontalScrollBarVisibility="Disabled">
        <Border Classes="info-panel">
            <StackPanel Spacing="10">
                <!-- Header: Close + Recording Title -->
                <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0"
                            Classes="info-close"
                            Command="{Binding ClosePanelCommand}"
                            Margin="0,0,10,0">
                        <ti:TablerIcon Icon="IconX" Width="17" Height="17" />
                    </Button>
                    <TextBlock Grid.Column="1"
                               Classes="info-piece-title"
                               Text="{Binding Title}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- Quick Info Placeholder -->
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0"
                            Classes="info-cover-placeholder"
                            VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0"
                                Spacing="4"
                                VerticalAlignment="Top">
                        <TextBlock Classes="info-meta-text"
                                   Text="Recording Profile"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="info-meta-text"
                                   Text="Label / Format / Details"
                                   TextWrapping="Wrap"
                                   Opacity="0.6" />
                    </StackPanel>
                </Grid>

                <!-- Large Actions -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Classes="info-play-button"
                            IsEnabled="False">
                        <ti:TablerIcon Icon="IconPlayerPlay" Width="20" Height="20" />
                    </Button>
                    <Button Classes="info-square-outline"
                            IsEnabled="False">
                        <ti:TablerIcon Icon="IconCornerUpLeft" Width="21" Height="21" />
                    </Button>
                    <Button Classes="info-square-outline"
                            IsEnabled="False">
                        <ti:TablerIcon Icon="IconCornerDownLeft" Width="21" Height="21" />
                    </Button>
                    <Button Classes="info-square-outline"
                            IsEnabled="False">
                        <ti:TablerIcon Icon="IconPlaylist" Width="21" Height="21" />
                    </Button>
                    <Button Classes="info-square-outline"
                            IsEnabled="False">
                        <ti:TablerIcon Icon="IconHeart" Width="21" Height="21" />
                    </Button>
                </StackPanel>

                <!-- Movements List grouped by Work -->
                <StackPanel Spacing="4">
                    <TextBlock Classes="info-section-heading" Text="Movements" />
                    <ScrollViewer MaxHeight="380"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding WorkGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:RecordingWorkGroupViewModel}">
                                    <StackPanel Margin="0,0,0,12">
                                        <!-- Emphasized Work Title -->
                                        <Button Classes="info-link"
                                                Command="{Binding ShowWorkCommand}"
                                                Margin="0,0,0,6">
                                            <TextBlock Classes="info-work-subtitle"
                                                       Text="{Binding WorkTitle}"
                                                       TextWrapping="Wrap" />
                                        </Button>
                                        <!-- Movement recordings under this Work -->
                                        <ItemsControl ItemsSource="{Binding Movements}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:RecordingMovementRowViewModel}">
                                                     <Grid Margin="0,0,0,4"
                                                           ColumnDefinitions="20,*,Auto"
                                                           MinHeight="28">
                                                         <TextBlock Grid.Column="0"
                                                                    Classes="info-ordinal"
                                                                    Text="{Binding OrdinalLabel}" />
                                                         <Button Grid.Column="1"
                                                                 Classes="info-link"
                                                                 Margin="4,0,8,0"
                                                                 Command="{Binding ShowMovementRecordingCommand}">
                                                             <TextBlock Classes="info-movement-name"
                                                                        Text="{Binding Name}"
                                                                        TextWrapping="Wrap" />
                                                         </Button>
                                                         <controls:OptionsButton Grid.Column="2" MenuOptions="{Binding MenuOptions}" Width="24" Height="24" />
                                                     </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
