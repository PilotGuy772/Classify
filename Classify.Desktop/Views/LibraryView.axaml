<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Classify.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Classify.Desktop.Views.LibraryView"
             x:DataType="viewModels:LibraryViewModel">
    <DockPanel Margin="12">

        <!-- Selector -->
        <DockPanel DockPanel.Dock="Top"
                   LastChildFill="False"
                   Margin="0,0,0,8">

            <!-- Scan button (right-aligned) -->
            <Button Content="Scan Library"
                    DockPanel.Dock="Right"
                    Click="ScanLibrary"
                    Margin="8,0,0,0"/>

            <!-- Radio buttons (left-aligned) -->
            <StackPanel Orientation="Horizontal"
                        Spacing="12">

                <RadioButton Content="Composers"
                             GroupName="Library"
                             IsChecked="{Binding SelectedType,
                                 Converter={StaticResource EnumEquals},
                                 ConverterParameter=Composer}" />

                <RadioButton Content="Works"
                             GroupName="Library"
                             IsChecked="{Binding SelectedType,
                                 Converter={StaticResource EnumEquals},
                                 ConverterParameter=Work}" />

                <RadioButton Content="Movements"
                             GroupName="Library"
                             IsChecked="{Binding SelectedType,
                                 Converter={StaticResource EnumEquals},
                                 ConverterParameter=Movement}" />

                <RadioButton Content="Recordings"
                             GroupName="Library"
                             IsChecked="{Binding SelectedType,
                                 Converter={StaticResource EnumEquals},
                                 ConverterParameter=Recording}" />

                <RadioButton Content="Audio Files"
                             GroupName="Library"
                             IsChecked="{Binding SelectedType,
                                 Converter={StaticResource EnumEquals},
                                 ConverterParameter=AudioFile}" />
            </StackPanel>

        </DockPanel>


        <!-- List -->
        <ListBox ItemsSource="{Binding Items}"
                 DoubleTapped="ItemDoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayText}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>
</UserControl>
