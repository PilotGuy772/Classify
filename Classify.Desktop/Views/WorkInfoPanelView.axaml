<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Classify.Desktop.ViewModels"
             xmlns:ti="using:TablerIcons"
             xmlns:controls="clr-namespace:Classify.Desktop.Controls"
             mc:Ignorable="d" d:DesignWidth="304" d:DesignHeight="776"
             x:Class="Classify.Desktop.Views.WorkInfoPanelView"
             x:DataType="viewModels:WorkInfoPanelViewModel"
             x:Name="PanelRoot">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Border Classes="info-panel">
            <StackPanel Spacing="10">
                <!-- Header: Close + Piece Title -->
                <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0"
                            Classes="info-close"
                            Command="{Binding ClosePanelCommand}"
                            Margin="0,0,10,0">
                        <ti:TablerIcon Icon="IconX" Width="12" Height="12" />
                    </Button>
                    <TextBlock Grid.Column="1"
                               Classes="info-piece-title"
                               Text="{Binding PieceTitle}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- Quick Info: cover placeholder + composer lines -->
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0"
                            Classes="info-cover-placeholder"
                            VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0"
                                Spacing="4"
                                VerticalAlignment="Top">
                        <TextBlock Classes="info-meta-text"
                                   Text="{Binding ComposerLine}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="info-meta-text"
                                   Text="{Binding SecondaryLine}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <!-- Large actions -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Classes="info-large-primary"
                            Width="58"
                            Height="35"
                            Command="{Binding PlayWorkCommand}">
                        <ti:TablerIcon Icon="IconPlayerPlay" Width="16" Height="16" />
                    </Button>
                    <Button Classes="info-large-outline"
                            Width="100"
                            Height="35"
                            Command="{Binding EnqueueWorkCommand}"
                            Content="Enqueue" />
                    <Button Classes="info-large-outline"
                            Width="100"
                            Height="35"
                            Command="{Binding AddWorkToPlaylistCommand}"
                            Content="Add to Playlist" />
                </StackPanel>

                <!-- Movements -->
                <StackPanel Spacing="4">
                    <TextBlock Classes="info-section-heading" Text="Movements" />
                    <ItemsControl ItemsSource="{Binding MovementRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:MovementInfoRowViewModel}">
                                    <Grid Margin="0,0,0,4"
                                          ColumnDefinitions="Auto,*,Auto"
                                          MinHeight="28">
                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Text="{Binding OrdinalLabel}"
                                                   Width="28" />
                                        <Button Grid.Column="1"
                                                Classes="info-link"
                                                Command="{Binding ShowMovementCommand}">
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       Text="{Binding Name}"
                                                       TextWrapping="Wrap" />
                                        </Button>
                                        <controls:OptionsButton Grid.Column="2" MenuOptions="{Binding MenuOptions}" />
                                    </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Recordings -->
                <StackPanel Spacing="4">
                    <TextBlock Classes="info-section-heading" Text="Recordings" />
                    <ScrollViewer MaxHeight="290"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RecordingRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:RecordingInfoRowViewModel}">
                                    <Grid Margin="0,0,0,4"
                                          ColumnDefinitions="*,Auto"
                                          MinHeight="31">
                                        <Button Grid.Column="0"
                                                Classes="info-link"
                                                Margin="0,0,8,0"
                                                Command="{Binding ShowRecordingCommand}">
                                            <TextBlock FontSize="12"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       Text="{Binding DisplayInfo}"
                                                       TextWrapping="Wrap" />
                                        </Button>
                                        <controls:OptionsButton Grid.Column="1" MenuOptions="{Binding MenuOptions}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
