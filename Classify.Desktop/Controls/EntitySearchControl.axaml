<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:Classify.Core.Interfaces.Service;assembly=Classify.Core"
             x:Class="Classify.Desktop.Controls.EntitySearchControl"
             x:Name="Root">

  <StackPanel Spacing="4">
    <!-- Pills -->
    <ItemsControl x:Name="PillsPanel" ItemsSource="{Binding SelectedItems, ElementName=Root}">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Background="#EEE" CornerRadius="12" Padding="6" Margin="0,0,6,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="{Binding}" />
              <Button Content="x" Command="{Binding RemovePillCommand, ElementName=Root}" CommandParameter="{Binding}" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
    </ItemsControl>

    <!-- Search Box -->
    <TextBox x:Name="SearchBox" Watermark="Search…" />

    <!-- Suggestions -->
    <ListBox x:Name="SuggestionsList" Height="120" ItemsSource="{Binding Suggestions, ElementName=Root}">
      <ListBox.ItemTemplate>
        <DataTemplate DataType="svc:SearchResult">
          <TextBlock Text="{Binding DisplayText}" />
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </StackPanel>

</UserControl>



