<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Classify.Desktop.App"
             xmlns:desktop="clr-namespace:Classify.Desktop"
             xmlns:converters="clr-namespace:Classify.Desktop.Converters"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
             
    <Application.Styles>
        <FluentTheme />
        <!-- Base semantic styles -->
        <StyleInclude Source="avares://Classify.Desktop/Styles/Base.axaml" />
        <!-- Platform-specific overrides (empty by default) -->
        <StyleInclude Source="avares://Classify.Desktop/Styles/Platform/macos.axaml" />
        <StyleInclude Source="avares://Classify.Desktop/Styles/Platform/linux.axaml" />
        <StyleInclude Source="avares://Classify.Desktop/Styles/Platform/windows.axaml" />
    </Application.Styles>
             
    <Application.DataTemplates>
        <desktop:ViewLocator/>
    </Application.DataTemplates>
             
    <Application.Resources>
        <converters:EnumEqualsConverter x:Key="EnumEquals" />
    </Application.Resources>
             
     

</Application>