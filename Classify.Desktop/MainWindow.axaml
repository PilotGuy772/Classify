<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Classify.Desktop.ViewModels"
        xmlns:views="clr-namespace:Classify.Desktop.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Classify.Desktop.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        Title="Classify.Desktop">

        <Grid RowDefinitions="Auto,*">
                <Grid.ColumnDefinitions>
                        <!-- Sidebar: start at 315px, but enforce a minimum of 180px -->
                        <ColumnDefinition Width="315" MinWidth="180" />
                        <!-- Splitter column (grab area) -->
                        <ColumnDefinition Width="6" />
                        <!-- Main content takes remaining space -->
                        <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar (now below the top toolbar) -->
                <Border Grid.Row="1"
                        Grid.Column="0"
                        Classes="sidebar"
                        MinWidth="160">
                        <!-- Make the sidebar vertically scrollable when content exceeds the window height -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="12">
                                <Button x:Name="HomeButton"
                                        Classes="sidebar-main-title"
                                        Click="HomeClicked">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Classes="sidebar-nav-icon" Text="♪" Width="30" Height="30" FontSize="34"/>
                                                <TextBlock Classes="sidebar-main-title-text" Text="Classify"/>
                                        </StackPanel>
                                </Button>

                                <TextBlock Classes="sidebar-category-title" Text="Library"/>

                                <Button x:Name="PlaylistsButton"
                                        Classes="sidebar-nav-button"
                                        Click="PlaylistsClicked">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Classes="sidebar-nav-icon" Text="≣"/>
                                                <TextBlock Classes="sidebar-nav-label" Text="Playlists"/>
                                        </StackPanel>
                                </Button>

                                <Button x:Name="BrowseButton"
                                        Classes="sidebar-nav-button"
                                        Click="BrowseClicked">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Classes="sidebar-nav-icon" Text="◉"/>
                                                <TextBlock Classes="sidebar-nav-label" Text="Browse"/>
                                        </StackPanel>
                                </Button>

                                <Button x:Name="ScanButton"
                                        Classes="sidebar-nav-button"
                                        Click="ScanClicked">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Classes="sidebar-nav-icon" Text="▤"/>
                                                <TextBlock Classes="sidebar-nav-label" Text="Scan"/>
                                        </StackPanel>
                                </Button>

                                <TextBlock Classes="sidebar-category-title" Text="Listen"/>

                                <Button x:Name="FavoritesButton"
                                        Classes="sidebar-nav-button"
                                        Click="FavoritesClicked">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Classes="sidebar-nav-icon" Text="♡"/>
                                                <TextBlock Classes="sidebar-nav-label" Text="Favorites"/>
                                        </StackPanel>
                                </Button>

                                <Button x:Name="ExploreButton"
                                        Classes="sidebar-nav-button"
                                        Click="ExploreClicked">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Classes="sidebar-nav-icon" Text="◌"/>
                                                <TextBlock Classes="sidebar-nav-label" Text="Explore"/>
                                        </StackPanel>
                                </Button>

                                <Button x:Name="RadioButton"
                                        Classes="sidebar-nav-button"
                                        Click="RadioClicked">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Classes="sidebar-nav-icon" Text="◍"/>
                                                <TextBlock Classes="sidebar-nav-label" Text="Radio"/>
                                        </StackPanel>
                                </Button>
                                </StackPanel>
                        </ScrollViewer>
                </Border>

                <!-- Splitter between sidebar and content -->
                <GridSplitter Grid.Row="1"
                              Grid.Column="1"
                              Classes="sidebar-splitter"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />

                <!-- Top bar (spans full width) -->
                <Border Grid.Row="0"
                        Grid.ColumnSpan="3"
                        Classes="titlebar">
                        <!-- Use a grid so we can reserve a top-left region for macOS traffic lights (hit-testable)
                             The left column is a transparent spacer that users can click/drag to move the window. -->
                        <Grid>
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Spacer for macOS traffic lights. Background="Transparent" keeps it hit-testable. -->
                                <Border Name="MacTrafficLightsSpacer"
                                        Width="90"
                                        Height="36"
                                        Background="Transparent"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        PointerPressed="MacTrafficLightsSpacer_PointerPressed" />

                                <TextBox Grid.Column="1" Watermark="Search…" />
                        </Grid>
                </Border>

                <!-- Main content + optional right Info Panel -->
                <Grid x:Name="InnerSplitGrid"
                      Grid.Row="1"
                      Grid.Column="2">
                        <Grid.ColumnDefinitions>
                                <!-- Primary page -->
                                <ColumnDefinition Width="*" MinWidth="120" />
                                <!-- Splitter between content and Info Panel -->
                                <ColumnDefinition Width="0" MinWidth="0" />
                                <!-- Info Panel column (width toggled from code-behind) -->
                                <ColumnDefinition Width="0"
                                                  MinWidth="0"
                                                  MaxWidth="520" />
                        </Grid.ColumnDefinitions>

                        <ContentControl Grid.Column="0"
                                        Content="{Binding CurrentPage}" />

                        <GridSplitter x:Name="InfoPanelSplitter"
                                      Grid.Column="1"
                                      Classes="info-splitter"
                                      ResizeDirection="Columns"
                                      ResizeBehavior="PreviousAndNext"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      IsHitTestVisible="False" />

                        <views:WorkInfoPanelView Grid.Column="2"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Stretch"
                                                 DataContext="{Binding WorkInfo}" />
                </Grid>
        </Grid>
    
</Window>
